# X/Twitter API credentials
# Get these from https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Your bot's numeric user ID
# Find it at https://tweeterid.com after creating the @mtgvisualizer account
X_BOT_USER_ID=

# Anthropic API key for Claude Vision OCR
ANTHROPIC_API_KEY=

# Base URL of your deployed deck viewer (no trailing slash)
DECK_VIEWER_URL=https://your-app.up.railway.app

# How often to check for new mentions (seconds)
POLL_INTERVAL=60
